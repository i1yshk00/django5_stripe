# Базовые настройки Django.
#
# Секретный ключ проекта.
# Для локальной разработки можно оставить dev-значение, но для production
# обязательно нужно использовать длинный случайный ключ.
DJANGO_SECRET_KEY=django-insecure-local-dev-only-change-me

# Включает режим отладки Django.
# Используется только в dev-окружении. В production должен быть False.
DJANGO_DEBUG=True

# Список доменов и хостов, с которых Django принимает запросы.
# В локальной разработке сюда входят localhost и loopback-адреса.
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Список доверенных origin для CSRF-проверки.
# Нужен для форм и AJAX-запросов, которые меняют состояние приложения.
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Отдельные production-like значения для Docker запуска без флага `-d`.
# Это позволяет не смешивать dev HTTP-настройки с prod HTTPS-профилем.
DJANGO_ALLOWED_HOSTS_PROD=localhost,127.0.0.1,0.0.0.0
DJANGO_CSRF_TRUSTED_ORIGINS_PROD=https://localhost:8000,https://127.0.0.1:8000

# Включать ли Postgres как основной database backend.
# В dev можно оставить False и работать на SQLite.
# В production и production-like Docker запуске должен быть True.
DJANGO_USE_POSTGRES=False

# Время жизни открытого DB-соединения в секундах.
# Для production это уменьшает накладные расходы на частое переподключение.
DJANGO_DB_CONN_MAX_AGE=60

# Уровень логирования приложения.
# Для локальной разработки удобно DEBUG, для production чаще используют INFO.
DJANGO_LOG_LEVEL=INFO

# Применять ли миграции автоматически при старте контейнера.
# Это полезно для Docker-окружений, чтобы не запускать `manage.py migrate` вручную.
DJANGO_RUN_MIGRATIONS_ON_STARTUP=true

# Выполнять ли `collectstatic` автоматически при старте контейнера.
# Для production обычно включено, для локального dev-контейнера можно отключить.
DJANGO_COLLECTSTATIC_ON_STARTUP=true

# Настройки Postgres.
#
# Эти переменные используются, если включен `DJANGO_USE_POSTGRES=True`
# и не задан единый `DATABASE_URL`.
POSTGRES_DB=django5_stripe
POSTGRES_USER=django5_stripe
POSTGRES_PASSWORD=django5_stripe
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Альтернативный способ передать строку подключения к Postgres.
# Удобен для managed database на Render, Fly.io, Railway и подобных платформах.
# Если `DATABASE_URL` задан, он имеет приоритет над отдельными `POSTGRES_*`.
DATABASE_URL=

# Настройки Stripe.
#
# Секретный ключ Stripe для серверных запросов.
# Используется только на бэкенде при создании Checkout Session,
# Payment Intent и обработке webhook-событий.
STRIPE_SECRET_KEY=sk_test_change_me

# Публичный ключ Stripe для клиентского Stripe.js.
# Этот ключ подставляется в HTML и используется в браузере.
STRIPE_PUBLISHABLE_KEY=pk_test_change_me

# Опциональные ключи для USD-потока.
# Если заданы, приложение будет использовать их для всех товаров и заказов в USD.
# Если не заданы, используется общий STRIPE_SECRET_KEY / STRIPE_PUBLISHABLE_KEY.
STRIPE_USD_SECRET_KEY=sk_test_change_me
STRIPE_USD_PUBLISHABLE_KEY=pk_test_change_me

# Опциональные ключи для EUR-потока.
# Это позволяет разнести keypair по валютам, как требует bonus-пункт ТЗ.
# Если проект использует один Stripe account на обе валюты, можно оставить
# те же значения, что и у общих ключей.
STRIPE_EUR_SECRET_KEY=sk_test_change_me
STRIPE_EUR_PUBLISHABLE_KEY=pk_test_change_me

# Секрет подписи webhook-событий Stripe.
# Нужен серверу для проверки заголовка Stripe-Signature и безопасного обновления
# статусов заказов после успешной или неуспешной оплаты.
STRIPE_WEBHOOK_SECRET=whsec_change_me

# Зафиксированная версия Stripe API, на которую ориентирован проект.
# Она должна совпадать с версией, которую использует серверная интеграция.
STRIPE_API_VERSION=2026-02-25.clover

# Внешний базовый URL приложения.
# Используется для сборки абсолютных success_url и cancel_url при создании
# Stripe Checkout Session.
DOMAIN_URL=http://localhost:8000

# Отдельный production-like URL для `docker-compose.yml`.
# Нужен, чтобы prod-профиль не наследовал локальный HTTP `DOMAIN_URL`.
DOMAIN_URL_PROD=https://localhost:8000
